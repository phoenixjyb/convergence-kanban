# ─────────────────────────────────────────────────────────────────────────
# ConvergenceKanban — environment configuration
# Copy to .env and fill in the values you need.
# Only PORT is required for a kanban-only deployment.
# Feishu integration is fully optional — leave those values blank to disable.
# ─────────────────────────────────────────────────────────────────────────

# ── Core server ──────────────────────────────────────────────────────────
PORT=8666                                    # HTTP port the kanban listens on
KANBAN_DATA_DIR=./data                       # SQLite + uploads live here

# Public URLs used when generating links (in card messages, etc.).
# Leave blank for localhost development.
KANBAN_WEB_URL=                              # e.g. https://kanban.example.com
KANBAN_API_URL=                              # e.g. https://kanban.example.com/api


# ── Feishu / Lark integration (optional) ────────────────────────────────
# Enable by creating a custom app on the Feishu Open Platform
# (https://open.feishu.cn/app) and pasting the credentials below.
# See docs/SETUP.md for the full walkthrough including required scopes.

FEISHU_APP_ID=                               # cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=                           # the app secret
FEISHU_PROFILE=                              # optional named profile (loads .env.<name>)

# Webhook URL for the Feishu group bot (for posting notifications).
# Different from the "custom app" above — this is a "group bot" webhook.
# https://www.feishu.cn/hc/en-US/articles/360024984973
FEISHU_WEBHOOK_URL=

# Event-callback credentials (only needed if using the chat-bot's event
# subscription mode, not the long-poll mode that's default).
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=


# ── Slack notifications (optional) ──────────────────────────────────────
# Bug/blocker/task events post to the channel attached to this webhook.
# Create an Incoming Webhook at: https://api.slack.com/messaging/webhooks
# Pick the channel you want notifications in. Free, no app install required.
# Format: https://hooks.slack.com/services/<TEAM_ID>/<CHANNEL_ID>/<WEBHOOK_TOKEN>
SLACK_WEBHOOK_URL=


# ── DingTalk / 钉钉 notifications (optional) ────────────────────────────
# Group bot webhook. In the DingTalk group → Settings → Group Assistant →
# Add Robot → Custom → copy the Webhook URL.
# Format: https://oapi.dingtalk.com/robot/send?access_token=XXXX...
DINGTALK_WEBHOOK_URL=
# Optional: HMAC-SHA256 secret if you enable signature verification.
# Recommended for any group that contains people outside your org.
DINGTALK_WEBHOOK_SECRET=


# ── Sync behaviour ──────────────────────────────────────────────────────
SYNC_INTERVAL=30                             # seconds between sync cycles


# ── Feishu wiki layout (for the QA-ticket integration) ─────────────────
# If you're using the QA-ticket feature (POST /api/qa-tickets), the bot
# creates ticket pages under a wiki sub-page using a template. Get these
# tokens by browsing your team's wiki — see docs/SETUP.md.
# Leave blank to disable the /api/qa-tickets endpoint.
KANBAN_QA_WIKI_SPACE_ID=
KANBAN_QA_WIKI_PARENT_NODE=
KANBAN_QA_WIKI_TEMPLATE_NODE=
KANBAN_QA_WIKI_SUBDOMAIN=                    # e.g. yourorg.feishu.cn


# ── Misc ─────────────────────────────────────────────────────────────────
BOT_DEBUG=                                   # set to 1 to verbose-log the chat bot
